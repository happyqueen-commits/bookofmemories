# ==============================
# Required in all environments
# ==============================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookofmemories?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters"

# ==============================
# Required for correct links/callbacks in production
# ==============================
# Public base URL of the application (used by auth callbacks and email links)
NEXTAUTH_URL="http://localhost:3000"
# Fallback for absolute links if NEXTAUTH_URL is unset
APP_URL="http://localhost:3000"

# Comma-separated origins allowed for Next.js Server Actions CSRF protection
# Example: ALLOWED_ORIGINS="book.example.com,www.book.example.com"
ALLOWED_ORIGINS="localhost:3000,127.0.0.1:3000"

# Runtime bind settings (for VPS/PM2)
HOST="127.0.0.1"
PORT="3000"

# ==============================
# Optional integrations
# ==============================
# Needed only when image upload uses Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# Webhook for password reset email delivery
PASSWORD_RESET_EMAIL_WEBHOOK_URL=""

# Webhook for submission status verification code delivery
SUBMISSION_ACCESS_EMAIL_WEBHOOK_URL=""
